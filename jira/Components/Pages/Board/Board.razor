@page "/board"
@page "/board/{BoardId:int}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using jira.Components.UI.StatusColumn
@using jira.Components.UI.TicketCard
@using jira.Data
@using jira.DbModels
@using jira.Services
@implements IAsyncDisposable
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject BoardStateService BoardState

@if (isLoading)
{
    <div class="board-loading">
        <span class="board-spinner"></span>
        <span>Ładowanie tablicy...</span>
    </div>
}
else if (board == null)
{
    <div class="board-not-found">
        <h3>Tablica nie istnieje lub nie masz do niej dostępu.</h3>
        <a href="/projects" class="board-back-link">← Wróć do tablic</a>
    </div>
}
else
{
    <!-- ── Confirm delete overlay ── -->
    @if (showDeleteConfirm)
    {
        <div class="board-delete-overlay">
            <div class="board-delete-dialog">
                <h4>Usuń tablicę</h4>
                <p>Czy na pewno chcesz usunąć tablicę <strong>@board.NazwaTablicy</strong>?<br />
                   Wszystkie zadania zostaną trwale usunięte.</p>
                <div class="board-delete-actions">
                    <button class="board-delete-cancel" @onclick="() => showDeleteConfirm = false" disabled="@isDeleting">
                        Anuluj
                    </button>
                    <button class="board-delete-confirm" @onclick="DeleteBoardAsync" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="board-delete-spinner"></span>
                            <span>Usuwanie...</span>
                        }
                        else
                        {
                            <span>🗑 Tak, usuń</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- ── Board header ── -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="board-title-group">
            @if (!string.IsNullOrEmpty(board.KolorTablicy))
            {
                <span class="board-color-dot" style="background:@board.KolorTablicy;"></span>
            }
            <h2 class="board-page-title">@board.NazwaTablicy</h2>
        </div>

        <div class="d-flex gap-2 align-items-center">
            @if (canDelete)
            {
                <button type="button" class="board-btn-delete" @onclick="() => showDeleteConfirm = true">
                    🗑 Usuń tablicę
                </button>
            }
            @if (canInvite)
            {
                <button type="button" class="btn btn-outline-secondary" @onclick="OpenInvitePanel">
                    👥 Zaproś do tablicy
                </button>
            }
            @if (canAddTask)
            {
                <a class="btn btn-primary" href="@($"/ticket/new?boardId={board.IdTablicy}")" >+ Dodaj zadanie</a>
            }
        </div>
    </div>

    <!-- ── Kanban columns ── -->
    <div class="kanban-board">
        <StatusColumn Title="Do zrobienia (To Do)" ColumnKey="Todo" OnDrop="HandleDrop">
            @foreach (var task in GetTasksByColumn("Todo"))
            {
                var t = task;
                <TicketCard Task="t" OnClick="OpenTicketModal"
                            OnDragStart="SetDraggedTask"
                            OnDragEnd="ClearDraggedTask" />
            }
        </StatusColumn>
        <StatusColumn Title="W trakcie (In Progress)" ColumnKey="In Progress" OnDrop="HandleDrop">
            @foreach (var task in GetTasksByColumn("In Progress"))
            {
                var t = task;
                <TicketCard Task="t" OnClick="OpenTicketModal"
                            OnDragStart="SetDraggedTask"
                            OnDragEnd="ClearDraggedTask" />
            }
        </StatusColumn>
        <StatusColumn Title="W weryfikacji (In Review)" ColumnKey="In Review" OnDrop="HandleDrop">
            @foreach (var task in GetTasksByColumn("In Review"))
            {
                var t = task;
                <TicketCard Task="t" OnClick="OpenTicketModal"
                            OnDragStart="SetDraggedTask"
                            OnDragEnd="ClearDraggedTask" />
            }
        </StatusColumn>
        <StatusColumn Title="Zakończone (Done)" ColumnKey="Done" OnDrop="HandleDrop">
            @foreach (var task in GetTasksByColumn("Done"))
            {
                var t = task;
                <TicketCard Task="t" OnClick="OpenTicketModal"
                            OnDragStart="SetDraggedTask"
                            OnDragEnd="ClearDraggedTask" />
            }
        </StatusColumn>
    </div>

    <!-- ── Invite panel (slide-in) ── -->
    @if (showInvitePanel)
    {
        <div class="invite-overlay" @onclick="CloseInvitePanel">
            <div class="invite-panel" @onclick:stopPropagation="true">
                <div class="invite-panel-header">
                    <h5>👥 Zaproś do tablicy</h5>
                    <button class="invite-panel-close" @onclick="CloseInvitePanel" title="Zamknij">✕</button>
                </div>

                <!-- Search -->
                <div class="invite-search-wrap">
                    <span class="invite-search-icon">🔍</span>
                    <input class="invite-search-input"
                           type="text"
                           placeholder="Szukaj po nazwie lub e-mailu..."
                           value="@inviteSearchQuery"
                           @oninput="OnInviteSearchInput"
                           autocomplete="off"
                           id="invite-search-input" />
                    @if (isInviteSearching)
                    {
                        <span class="invite-search-spinner"></span>
                    }
                </div>

                <!-- Search results dropdown -->
                @if (inviteSearchResults.Count > 0 && inviteSelectedUser == null)
                {
                    <ul class="invite-results">
                        @foreach (var u in inviteSearchResults)
                        {
                            var usr = u;
                            <li class="invite-result-item" @onclick="() => SelectInviteUser(usr)">
                                <div class="invite-result-avatar" style="background: @GetAvatarColor(usr.NazwaUzytkownika)">
                                    @if (!string.IsNullOrEmpty(usr.AvatarUrl))
                                    {
                                        <img src="@usr.AvatarUrl" alt="@usr.NazwaUzytkownika" class="invite-result-avatar-img" />
                                    }
                                    else
                                    {
                                        @usr.NazwaUzytkownika.Substring(0, 1).ToUpperInvariant()
                                    }
                                </div>
                                <div class="invite-result-info">
                                    <span class="invite-result-name">@usr.NazwaUzytkownika</span>
                                    <span class="invite-result-email">@usr.Email</span>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else if (!string.IsNullOrEmpty(inviteSearchQuery) && inviteSearchQuery.Length >= 2
                         && inviteSearchResults.Count == 0 && !isInviteSearching && inviteSelectedUser == null)
                {
                    <div class="invite-no-results">Brak użytkowników pasujących do „@inviteSearchQuery"</div>
                }

                <!-- Selected user card -->
                @if (inviteSelectedUser != null)
                {
                    <div class="invite-selected-card">
                        <div class="invite-result-avatar invite-selected-avatar"
                             style="background: @GetAvatarColor(inviteSelectedUser.NazwaUzytkownika)">
                            @if (!string.IsNullOrEmpty(inviteSelectedUser.AvatarUrl))
                            {
                                <img src="@inviteSelectedUser.AvatarUrl" alt="@inviteSelectedUser.NazwaUzytkownika" class="invite-result-avatar-img" />
                            }
                            else
                            {
                                @inviteSelectedUser.NazwaUzytkownika.Substring(0, 1).ToUpperInvariant()
                            }
                        </div>
                        <div class="invite-selected-info">
                            <strong>@inviteSelectedUser.NazwaUzytkownika</strong>
                            <span>@inviteSelectedUser.Email</span>
                        </div>
                        <button class="invite-deselect" @onclick="ClearInviteSelection" title="Zmień">✕</button>
                    </div>

                    <div class="invite-role-wrap">
                        <label class="invite-role-label">Rola w tablicy</label>
                        <div class="invite-role-options">
                            <label class="@(inviteSelectedRole == "member" ? "invite-role-option invite-role-option--active" : "invite-role-option")">
                                <input type="radio" name="invite-role" value="member"
                                       checked="@(inviteSelectedRole == "member")"
                                       @onchange="SetRoleMember" />
                                <span class="invite-role-icon">✏️</span>
                                <span>
                                    <strong>Członek</strong>
                                    <small>Może edytować zadania</small>
                                </span>
                            </label>
                            <label class="@(inviteSelectedRole == "viewer" ? "invite-role-option invite-role-option--active" : "invite-role-option")">
                                <input type="radio" name="invite-role" value="viewer"
                                       checked="@(inviteSelectedRole == "viewer")"
                                       @onchange="SetRoleViewer" />
                                <span class="invite-role-icon">👁</span>
                                <span>
                                    <strong>Obserwator</strong>
                                    <small>Tylko do odczytu</small>
                                </span>
                            </label>
                            <label class="@(inviteSelectedRole == "admin" ? "invite-role-option invite-role-option--active" : "invite-role-option")">
                                <input type="radio" name="invite-role" value="admin"
                                       checked="@(inviteSelectedRole == "admin")"
                                       @onchange="SetRoleAdmin" />
                                <span class="invite-role-icon">🛡</span>
                                <span>
                                    <strong>Administrator</strong>
                                    <small>Pełny dostęp</small>
                                </span>
                            </label>
                        </div>
                    </div>
                }

                <!-- Feedback messages -->
                @if (!string.IsNullOrEmpty(inviteSuccessMsg))
                {
                    <div class="invite-success">✅ @inviteSuccessMsg</div>
                }
                @if (!string.IsNullOrEmpty(inviteErrorMsg))
                {
                    <div class="invite-error">⚠️ @inviteErrorMsg</div>
                }

                <!-- Members already in board -->
                @if (board != null)
                {
                    <div class="invite-members-section">
                        <p class="invite-members-title">Obecni członkowie</p>
                        <ul class="invite-members-list">

                            <!-- Owner always shown first -->
                            @if (board.Owner != null)
                            {
                                <li class="invite-member-item">
                                    <div class="invite-result-avatar invite-member-avatar"
                                         style="background: @GetAvatarColor(board.Owner.NazwaUzytkownika)">
                                        @if (!string.IsNullOrEmpty(board.Owner.AvatarUrl))
                                        {
                                            <img src="@board.Owner.AvatarUrl" alt="" class="invite-result-avatar-img" />
                                        }
                                        else
                                        {
                                            @board.Owner.NazwaUzytkownika.Substring(0, 1).ToUpperInvariant()
                                        }
                                    </div>
                                    <div class="invite-member-info">
                                        <span>
                                            @board.Owner.NazwaUzytkownika
                                            @if (board.IdUzytkownikaOwner == currentUserId)
                                            {
                                                <span class="invite-member-you"> (Ty)</span>
                                            }
                                        </span>
                                        <span class="invite-member-role invite-member-role--owner">Właściciel</span>
                                    </div>
                                </li>
                            }

                            <!-- Participants from TABLICE_UZYTKOWNICY -->
                            @foreach (var m in boardMembers)
                            {
                                <li class="invite-member-item">
                                    <div class="invite-result-avatar invite-member-avatar"
                                         style="background: @GetAvatarColor(m.Uzytkownik?.NazwaUzytkownika ?? "?")">
                                        @if (!string.IsNullOrEmpty(m.Uzytkownik?.AvatarUrl))
                                        {
                                            <img src="@m.Uzytkownik.AvatarUrl" alt="" class="invite-result-avatar-img" />
                                        }
                                        else
                                        {
                                            @((m.Uzytkownik?.NazwaUzytkownika ?? "?").Substring(0, 1).ToUpperInvariant())
                                        }
                                    </div>
                                    <div class="invite-member-info">
                                        <span>
                                            @(m.Uzytkownik?.NazwaUzytkownika ?? "—")
                                            @if (m.IdUzytkownika == currentUserId)
                                            {
                                                <span class="invite-member-you"> (Ty)</span>
                                            }
                                        </span>
                                        <span class="invite-member-role invite-member-role--@m.Rola">@RoleLabel(m.Rola)</span>
                                    </div>
                                </li>
                            }

                        </ul>
                    </div>
                }

                <!-- Action button -->
                <div class="invite-panel-footer">
                    <button class="invite-btn-add"
                            disabled="@(inviteSelectedUser == null || isInviteSaving)"
                            @onclick="AddUserToBoardAsync">
                        @if (isInviteSaving)
                        {
                            <span class="invite-btn-spinner"></span>
                            <span>Dodawanie...</span>
                        }
                        else
                        {
                            <span>✓ Dodaj do tablicy</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- ── Ticket detail modal (Blazor-driven) ── -->
    @if (selectedTask != null)
    {
        <div class="ticket-modal-overlay" @onclick="CloseTicketModal">
            <div class="ticket-modal-dialog" @onclick:stopPropagation="true" role="dialog"
                 aria-modal="true" aria-labelledby="ticketModalTitle">

                <!-- Header -->
                <div class="ticket-modal-header">
                    <div class="ticket-modal-title-group">
                        <span class="ticket-modal-id">#@GetDisplayId(selectedTask.IdZadania)</span>
                        <h5 id="ticketModalTitle" class="ticket-modal-title">@selectedTask.TytulZadania</h5>
                    </div>
                    <button class="ticket-modal-close" @onclick="CloseTicketModal" title="Zamknij">✕</button>
                </div>

                <!-- Body -->
                <div class="ticket-modal-body">
                    <!-- Left: description + comments -->
                    <div class="ticket-modal-left">
                        <p class="ticket-modal-section-label">Opis</p>
                        @if (!string.IsNullOrWhiteSpace(selectedTask.OpisZadania))
                        {
                            <p class="ticket-modal-desc">@selectedTask.OpisZadania</p>
                        }
                        else
                        {
                            <p class="ticket-modal-desc ticket-modal-desc--empty">Brak opisu zadania.</p>
                        }

                        <!-- Comments section -->
                        <div class="comments-section">
                            <p class="ticket-modal-section-label comments-title">💬 Komentarze (@taskComments.Count)</p>

                            @if (isLoadingComments)
                            {
                                <div class="comments-loading">
                                    <span class="comments-spinner"></span>
                                    <span>Ładowanie komentarzy...</span>
                                </div>
                            }
                            else
                            {
                                @if (taskComments.Count == 0)
                                {
                                    <p class="comments-empty">Brak komentarzy. Bądź pierwszy!</p>
                                }
                                else
                                {
                                    <ul class="comments-list">
                                        @foreach (var comment in taskComments)
                                        {
                                            var c = comment;
                                            <li class="comment-item">
                                                <div class="comment-avatar"
                                                     style="background: @GetAvatarColor(c.Uzytkownik?.NazwaUzytkownika ?? "?")"
                                                     title="@(c.Uzytkownik?.NazwaUzytkownika ?? "Nieznany")">
                                                    @if (!string.IsNullOrEmpty(c.Uzytkownik?.AvatarUrl))
                                                    {
                                                        <img src="@c.Uzytkownik.AvatarUrl" alt="@c.Uzytkownik.NazwaUzytkownika" class="comment-avatar-img" />
                                                    }
                                                    else
                                                    {
                                                        @((c.Uzytkownik?.NazwaUzytkownika ?? "?").Substring(0, 1).ToUpperInvariant())
                                                    }
                                                </div>
                                                <div class="comment-body">
                                                    <div class="comment-meta">
                                                        <span class="comment-author">@(c.Uzytkownik?.NazwaUzytkownika ?? "Nieznany")</span>
                                                        <span class="comment-date">@FormatCommentDate(c.DataUtworzenia)</span>
                                                        @if (c.DataEdycji.HasValue)
                                                        {
                                                            <span class="comment-edited">(edytowano)</span>
                                                        }
                                                    </div>
                                                    @if (editingCommentId == c.IdKomentarza)
                                                    {
                                                        <textarea class="comment-edit-input"
                                                                  @bind="editCommentText"
                                                                  rows="3"></textarea>
                                                        <div class="comment-edit-actions">
                                                            <button class="comment-save-btn" @onclick="() => SaveEditedCommentAsync(c)"
                                                                    disabled="@isSavingComment">Zapisz</button>
                                                            <button class="comment-cancel-btn" @onclick="CancelEditComment">Anuluj</button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <p class="comment-text">@c.TrescKomentarza</p>
                                                        @if (c.IdUzytkownika == currentUserId)
                                                        {
                                                            <div class="comment-actions">
                                                                <button class="comment-action-btn" @onclick="() => StartEditComment(c)" title="Edytuj">✎ Edytuj</button>
                                                                <button class="comment-action-btn comment-action-btn--delete" @onclick="() => DeleteCommentAsync(c)" title="Usuń">🗑 Usuń</button>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }

                                @if (canAddTask)
                                {
                                    <!-- Add comment form (only non-viewers) -->
                                    <div class="comment-add-wrap">
                                        <div class="comment-add-avatar"
                                             style="background: @GetAvatarColor(currentUserName)">
                                            @if (!string.IsNullOrEmpty(currentUserAvatarUrl))
                                            {
                                                <img src="@currentUserAvatarUrl" alt="@currentUserName" class="comment-avatar-img" />
                                            }
                                            else
                                            {
                                                @(currentUserName.Length > 0 ? currentUserName.Substring(0, 1).ToUpperInvariant() : "?")
                                            }
                                        </div>
                                        <div class="comment-add-input-wrap">
                                            <textarea class="comment-add-input"
                                                      @bind="newCommentText"
                                                      @bind:event="oninput"
                                                      placeholder="Dodaj komentarz..."
                                                      rows="2"
                                                      id="comment-input-@selectedTask.IdZadania"></textarea>
                                            <div class="comment-add-footer">
                                                @if (!string.IsNullOrEmpty(commentError))
                                                {
                                                    <span class="comment-error">@commentError</span>
                                                }
                                                <button class="comment-submit-btn"
                                                        @onclick="AddCommentAsync"
                                                        disabled="@(isSavingComment || string.IsNullOrWhiteSpace(newCommentText))">
                                                    @if (isSavingComment)
                                                    {
                                                        <span class="comment-btn-spinner"></span>
                                                        <span>Zapisywanie...</span>
                                                    }
                                                    else
                                                    {
                                                        <span>Wyślij</span>
                                                    }
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <p class="comments-viewer-note">👁 Obserwatorzy mogą tylko czytać komentarze.</p>
                                }
                            }
                        </div>
                    </div>

                    <!-- Right: metadata -->
                    <div class="ticket-modal-right">
                        <p class="ticket-modal-section-label">Szczegóły</p>

                        <div class="ticket-modal-field">
                            <label class="ticket-modal-field-label">Status</label>
                            @if (isSavingStatus)
                            {
                                <span class="ticket-modal-saving">Zapisywanie...</span>
                            }
                            else if (canAddTask)
                            {
                                <select class="ticket-modal-select" value="@selectedTask.KolumnaTablicy"
                                        @onchange="ChangeTaskStatus">
                                    <option value="Todo">Do zrobienia</option>
                                    <option value="In Progress">W trakcie</option>
                                    <option value="In Review">W weryfikacji</option>
                                    <option value="Done">Zakończone</option>
                                </select>
                            }
                            else
                            {
                                <span class="ticket-modal-assignee">@StatusLabel(selectedTask.KolumnaTablicy)</span>
                            }
                        </div>

                        <div class="ticket-modal-field">
                            <label class="ticket-modal-field-label">Priorytet</label>
                            <span class="ticket-priority-badge ticket-priority-badge--@selectedTask.Priorytet.ToLower()">@PriorityDisplayLabel(selectedTask.Priorytet)</span>
                        </div>

                        <div class="ticket-modal-field">
                            <label class="ticket-modal-field-label">Przypisane do</label>

                            @if (!canAddTask)
                            {
                                @if (selectedTask.UzytkownikPrzypisany != null)
                                {
                                    <span class="ticket-modal-assignee">@selectedTask.UzytkownikPrzypisany.NazwaUzytkownika</span>
                                }
                                else
                                {
                                    <span class="ticket-modal-assignee ticket-modal-assignee--none">Nieprzypisane</span>
                                }
                            }
                            else
                            {
                                <div class="assign-widget">
                                    @if (selectedTask.UzytkownikPrzypisany != null && !assignSearchOpen)
                                    {
                                        <div class="assign-current">
                                            <div class="assign-avatar"
                                                 style="background: @GetAvatarColor(selectedTask.UzytkownikPrzypisany.NazwaUzytkownika)">
                                                @if (!string.IsNullOrEmpty(selectedTask.UzytkownikPrzypisany.AvatarUrl))
                                                {
                                                    <img src="@selectedTask.UzytkownikPrzypisany.AvatarUrl"
                                                         alt="@selectedTask.UzytkownikPrzypisany.NazwaUzytkownika"
                                                         class="assign-avatar-img" />
                                                }
                                                else
                                                {
                                                    @selectedTask.UzytkownikPrzypisany.NazwaUzytkownika.Substring(0, 1).ToUpperInvariant()
                                                }
                                            </div>
                                            <span class="assign-name">@selectedTask.UzytkownikPrzypisany.NazwaUzytkownika</span>
                                            <button class="assign-change-btn" @onclick="OpenAssignSearch" title="Zmień">✎</button>
                                        </div>
                                    }
                                    else if (!assignSearchOpen)
                                    {
                                        <div class="assign-empty-row">
                                            <span class="ticket-modal-assignee ticket-modal-assignee--none">Nieprzypisane</span>
                                            <button class="assign-open-btn" @onclick="OpenAssignSearch">+ Przypisz</button>
                                        </div>
                                    }

                                    @if (assignSearchOpen)
                                    {
                                        <div class="assign-search-wrap">
                                            <span class="assign-search-icon">🔍</span>
                                            <input class="assign-search-input"
                                                   type="text"
                                                   placeholder="Szukaj członka tablicy..."
                                                   value="@assignSearchQuery"
                                                   @oninput="OnAssignSearchInput"
                                                   autocomplete="off" />
                                            <button class="assign-cancel-btn" @onclick="CloseAssignSearch" title="Anuluj">✕</button>
                                        </div>

                                        <ul class="assign-results">
                                            <!-- zawsze widoczna opcja zwolnienia zadania -->
                                            <li class="assign-result-item assign-result-item--unassign" @onclick="UnassignAsync">
                                                <div class="assign-result-avatar assign-unassign-icon">✕</div>
                                                <div class="assign-result-info">
                                                    <span>Pozostaw puste</span>
                                                    <small>Usuń przypisanie</small>
                                                </div>
                                            </li>
                                            @foreach (var m in assignSearchResults)
                                            {
                                                var mu = m;
                                                <li class="assign-result-item" @onclick="() => AssignUserAsync(mu)">
                                                    <div class="assign-result-avatar"
                                                         style="background: @GetAvatarColor(mu.NazwaUzytkownika)">
                                                        @if (!string.IsNullOrEmpty(mu.AvatarUrl))
                                                        {
                                                            <img src="@mu.AvatarUrl" alt="@mu.NazwaUzytkownika" class="assign-avatar-img" />
                                                        }
                                                        else
                                                        {
                                                            @mu.NazwaUzytkownika.Substring(0, 1).ToUpperInvariant()
                                                        }
                                                    </div>
                                                    <div class="assign-result-info">
                                                        <span>@mu.NazwaUzytkownika</span>
                                                        <small>@mu.Email</small>
                                                    </div>
                                                </li>
                                            }
                                        </ul>
                                        @if (assignSearchQuery.Length >= 1 && assignSearchResults.Count == 0)
                                        {
                                            <div class="assign-no-results">Brak wyników dla „@assignSearchQuery"</div>
                                        }
                                    }

                                    @if (!isSavingAssign)
                                    {
                                        <button class="assign-me-btn" @onclick="AssignToMeAsync"
                                                title="Przypisz to zadanie do siebie">
                                            👤 Przypisz do mnie
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="ticket-modal-saving">Zapisywanie...</span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="ticket-modal-field">
                            <label class="ticket-modal-field-label">Data stworzenia</label>
                            <span class="ticket-modal-assignee">@selectedTask.DataStworzenia.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        </div>

                        @if (!string.IsNullOrEmpty(taskModalError))
                        {
                            <div class="ticket-modal-error">⚠️ @taskModalError</div>
                        }
                    </div>
                </div>

                <!-- Footer -->
                <div class="ticket-modal-footer">
                    @if (canAddTask)
                    {
                        <button class="ticket-modal-btn-delete" @onclick="DeleteTaskAsync"
                                disabled="@isDeletingTask">
                            @if (isDeletingTask)
                            {
                                <span>Usuwanie...</span>
                            }
                            else
                            {
                                <span>🗑 Usuń zadanie</span>
                            }
                        </button>
                    }
                    <button class="ticket-modal-btn-close" @onclick="CloseTicketModal">Zamknij</button>
                </div>
            </div>
        </div>
    }
}

@code {
    // ── Route param ────────────────────────────────
    [Parameter] public int? BoardId { get; set; }

