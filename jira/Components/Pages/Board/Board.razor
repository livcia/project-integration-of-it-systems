    private async Task AddCommentAsync()
    {
        if (selectedTask == null || string.IsNullOrWhiteSpace(newCommentText)) return;

        isSavingComment = true;
        commentError = null;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var komentarz = new Komentarz
            {
                IdZadania       = selectedTask.IdZadania,
                IdUzytkownika   = currentUserId,
                TrescKomentarza = newCommentText.Trim(),
                DataUtworzenia  = DateTime.UtcNow,
            };

            db.Komentarze.Add(komentarz);
            await db.SaveChangesAsync();

            // Load the user nav property
            komentarz.Uzytkownik = await db.Uzytkownicy.FindAsync(currentUserId);

            taskComments.Insert(0, komentarz);
            newCommentText = "";
        }
        catch (Exception ex)
        {
            commentError = $"Błąd dodawania komentarza: {ex.Message}";
        }
        finally
        {
            isSavingComment = false;
        }
    }

    private void StartEditComment(Komentarz komentarz)
    {
        editingCommentId = komentarz.IdKomentarza;
        editCommentText  = komentarz.TrescKomentarza;
    }

    private void CancelEditComment()
    {
        editingCommentId = null;
        editCommentText  = "";
    }

    private async Task SaveEditedCommentAsync(Komentarz komentarz)
    {
        if (string.IsNullOrWhiteSpace(editCommentText)) return;

        isSavingComment = true;
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var dbComment = await db.Komentarze.FindAsync(komentarz.IdKomentarza);
            if (dbComment != null)
            {
                dbComment.TrescKomentarza = editCommentText.Trim();
                dbComment.DataEdycji      = DateTime.UtcNow;
                await db.SaveChangesAsync();

                komentarz.TrescKomentarza = dbComment.TrescKomentarza;
                komentarz.DataEdycji      = dbComment.DataEdycji;
            }
            editingCommentId = null;
            editCommentText  = "";
        }
        catch (Exception ex)
        {
            commentError = $"Błąd edycji: {ex.Message}";
        }
        finally
        {
            isSavingComment = false;
        }
    }

    private async Task DeleteCommentAsync(Komentarz komentarz)
    {
        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var dbComment = await db.Komentarze.FindAsync(komentarz.IdKomentarza);
            if (dbComment != null)
            {
                db.Komentarze.Remove(dbComment);
                await db.SaveChangesAsync();
                taskComments.Remove(komentarz);
            }
        }
        catch (Exception ex)
        {
            commentError = $"Błąd usuwania komentarza: {ex.Message}";
        }
    }

    private static string FormatCommentDate(DateTime utc)
    {
        var local = utc.ToLocalTime();
        var now   = DateTime.Now;
        var diff  = now - local;
        if (diff.TotalMinutes < 1)   return "przed chwilą";
        if (diff.TotalMinutes < 60)  return $"{(int)diff.TotalMinutes} min temu";
        if (diff.TotalHours   < 24)  return $"{(int)diff.TotalHours} godz. temu";
        if (diff.TotalDays    < 7)   return $"{(int)diff.TotalDays} dni temu";
        return local.ToString("dd.MM.yyyy HH:mm");
    }

    // ── Assign widget ───────────────────────────────
    private void OpenAssignSearch()
    {
        assignSearchQuery   = "";
        assignSearchResults = BuildAssignResults("");
        assignSearchOpen    = true;
    }

    private void CloseAssignSearch()
    {
        assignSearchOpen    = false;
        assignSearchQuery   = "";
        assignSearchResults = new();
        _assignDebounceTimer?.Dispose();
    }

    private void OnAssignSearchInput(ChangeEventArgs e)
    {
        assignSearchQuery   = e.Value?.ToString() ?? "";
        assignSearchResults = BuildAssignResults(assignSearchQuery);
    }

    /// <summary>Filtruje lokalną listę boardMembers + owner wg wpisanej frazy (pomija viewerów).</summary>
    private List<Uzytkownik> BuildAssignResults(string query)
    {
        if (board == null) return new();

        var all = new List<Uzytkownik>();
        if (board.Owner != null) all.Add(board.Owner);
        foreach (var m in boardMembers)
        {
            if (m.Rola == "viewer") continue;
            if (m.Uzytkownik != null) all.Add(m.Uzytkownik);
        }

        if (string.IsNullOrWhiteSpace(query))
            return all;

        return all.Where(u =>
            u.NazwaUzytkownika.Contains(query, StringComparison.OrdinalIgnoreCase) ||
            u.Email.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private async Task AssignUserAsync(Uzytkownik user)
    {
        if (selectedTask == null) return;
        await SaveAssignmentAsync(user);
    }

    private async Task AssignToMeAsync()
    {
        if (selectedTask == null || board == null) return;

        Uzytkownik? me = null;
        if (board.Owner?.IdUzytkownika == currentUserId)
            me = board.Owner;
        else
            me = boardMembers.FirstOrDefault(m => m.IdUzytkownika == currentUserId)?.Uzytkownik;

        if (me == null)
        {
            using var s = ScopeFactory.CreateScope();
            var db = s.ServiceProvider.GetRequiredService<AppDbContext>();
            me = await db.Uzytkownicy.FindAsync(currentUserId);
        }

        if (me != null) await SaveAssignmentAsync(me);
    }

    private async Task UnassignAsync()
    {
        if (selectedTask == null) return;
        isSavingAssign = true;
        taskModalError = null;
        CloseAssignSearch();

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var dbTask = await db.Zadania.FindAsync(selectedTask.IdZadania);
            if (dbTask != null)
            {
                dbTask.IdUzytkownikaPrzypisanego = null;
                await db.SaveChangesAsync();

                selectedTask.IdUzytkownikaPrzypisanego = null;
                selectedTask.UzytkownikPrzypisany      = null;
            }
        }
        catch (Exception ex)
        {
            taskModalError = $"Błąd usuwania przypisania: {ex.Message}";
        }
        finally
        {
            isSavingAssign = false;
        }
    }

    private async Task SaveAssignmentAsync(Uzytkownik user)
    {
        if (selectedTask == null) return;
        isSavingAssign = true;
        taskModalError = null;
        CloseAssignSearch();

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var dbTask = await db.Zadania.FindAsync(selectedTask.IdZadania);
            if (dbTask != null)
            {
                dbTask.IdUzytkownikaPrzypisanego = user.IdUzytkownika;
                await db.SaveChangesAsync();

                selectedTask.IdUzytkownikaPrzypisanego = user.IdUzytkownika;
                selectedTask.UzytkownikPrzypisany      = user;
            }
        }
        catch (Exception ex)
        {
            taskModalError = $"Błąd przypisania: {ex.Message}";
        }
        finally
        {
            isSavingAssign = false;
        }
    }

    private async Task ChangeTaskStatus(ChangeEventArgs e)
    {
        if (selectedTask == null || board == null) return;

        var newColumn = e.Value?.ToString() ?? selectedTask.KolumnaTablicy;
        isSavingStatus = true;
        taskModalError = null;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var dbTask = await db.Zadania.FindAsync(selectedTask.IdZadania);
            if (dbTask != null)
            {
                dbTask.KolumnaTablicy = newColumn;
                dbTask.Status         = newColumn;
                await db.SaveChangesAsync();

                // Update in-memory
                selectedTask.KolumnaTablicy = newColumn;
                selectedTask.Status         = newColumn;
            }
        }
        catch (Exception ex)
        {
            taskModalError = $"Błąd zapisu: {ex.Message}";
        }
        finally
        {
            isSavingStatus = false;
        }
    }

    private async Task DeleteTaskAsync()
    {
        if (selectedTask == null || board == null) return;

        isDeletingTask = true;
        taskModalError = null;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var dbTask = await db.Zadania.FindAsync(selectedTask.IdZadania);
            if (dbTask != null)
            {
                db.Zadania.Remove(dbTask);
                await db.SaveChangesAsync();

                // Remove from in-memory collection
                var taskList = board.Zadania as ICollection<Zadanie>;
                taskList?.Remove(selectedTask);
            }

            CloseTicketModal();
        }
        catch (Exception ex)
        {
            taskModalError = $"Błąd usuwania: {ex.Message}";
            isDeletingTask = false;
        }
    }

    // ── Delete board ───────────────────────────────
    private async Task DeleteBoardAsync()
    {
        if (board == null) return;
        isDeleting = true;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            int boardIdToDelete = board.IdTablicy;

            var toDelete = await db.Tablice
                .Include(t => t.TabliceUzyt)
                .Include(t => t.Zadania)
                .FirstOrDefaultAsync(t =>
                    t.IdTablicy == boardIdToDelete &&
                    (t.IdUzytkownikaOwner == currentUserId ||
                     t.TabliceUzyt.Any(tu =>
                         tu.IdUzytkownika == currentUserId &&
                         tu.Rola == "admin")));

            if (toDelete != null)
            {
                db.Tablice.Remove(toDelete);
                await db.SaveChangesAsync();
                await BoardState.NotifyBoardCreatedAsync();
                NavManager.NavigateTo("/projects");
            }
        }
        catch
        {
            showDeleteConfirm = false;
            isDeleting = false;
        }
    }

    // ── Helpers ────────────────────────────────────
    /// <summary>
    /// Generuje deterministyczny, wielocyfrowy (6-znakowy) ID wyświetlany zamiast
    /// sekwencyjnego klucza bazy danych. Ten sam idZadania zawsze daje ten sam wynik.
    /// </summary>
    private static string GetDisplayId(int idZadania)
    {
        var seed = idZadania * 131071 + 47;
        var pseudo = (seed ^ (seed >> 16)) * 0x45d9f3b;
        pseudo = (pseudo ^ (pseudo >> 16)) * 0x45d9f3b;
        pseudo ^= pseudo >> 16;
        return (Math.Abs(pseudo) % 900_000 + 100_000).ToString();
    }

    // ── Cleanup ────────────────────────────────────
    public async ValueTask DisposeAsync()
    {
        _debounceTimer?.Dispose();
        await Task.CompletedTask;
    }
}