    private static string PriorityDisplayLabel(string priorytet) => priorytet.ToLower() switch
    {
        "wysoki" or "high"   => "Wysoki",
        "niski"  or "low"    => "Niski",
        _                    => "Średni"
    };

    private static string StatusLabel(string kolumna) => kolumna switch
    {
        "In Progress" => "W trakcie",
        "In Review"   => "W weryfikacji",
        "Done"        => "Zakończone",
