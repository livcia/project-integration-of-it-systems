    };

    // ── Ticket modal ────────────────────────────────
    private void OpenTicketModal(Zadanie task)
    {
        selectedTask        = task;
        taskModalError      = null;
        assignSearchOpen    = false;
        assignSearchQuery   = "";
        assignSearchResults = new();
        newCommentText      = "";
        commentError        = null;
        editingCommentId    = null;
        taskComments        = new();
        _ = LoadCommentsAsync(task.IdZadania);
    }

    private void CloseTicketModal()
    {
        selectedTask      = null;
        taskModalError    = null;
        assignSearchOpen  = false;
        taskComments      = new();
        editingCommentId  = null;
        _assignDebounceTimer?.Dispose();
