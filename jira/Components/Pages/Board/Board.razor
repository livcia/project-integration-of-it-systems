    private bool canAddTask;     // owner OR admin OR member (NOT viewer)
    private bool showDeleteConfirm;
    private bool isDeleting;

    // ── Ticket modal state ─────────────────────────
    private Zadanie? selectedTask;
    private bool isSavingStatus;
    private bool isDeletingTask;
    private string? taskModalError;
    private int currentUserId;
    private string currentUserName = "";
    private string? currentUserAvatarUrl;

    // ── Comments state ─────────────────────────────
    private List<Komentarz> taskComments = new();
    private bool isLoadingComments;
    private string newCommentText = "";
    private bool isSavingComment;
    private string? commentError;
    private int? editingCommentId;
    private string editCommentText = "";

    // Assign widget state
    private bool assignSearchOpen;
    private string assignSearchQuery = "";
    private List<Uzytkownik> assignSearchResults = new();
    private bool isSavingAssign;
    private System.Threading.Timer? _assignDebounceTimer = null;

    // ── Drag & drop state ──────────────────────────
    private Zadanie? draggedTask;

    private void SetDraggedTask(Zadanie task) => draggedTask = task;
    private void ClearDraggedTask() => draggedTask = null;

    private async Task HandleDrop(string targetColumn)
    {
        if (draggedTask == null || board == null) return;
        if (string.Equals(draggedTask.KolumnaTablicy, targetColumn, StringComparison.OrdinalIgnoreCase))
        {
            draggedTask = null;
            return;
        }

        var taskToMove = draggedTask;
        draggedTask = null;

        // Optimistic UI update
        taskToMove.KolumnaTablicy = targetColumn;
        taskToMove.Status         = targetColumn;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var dbTask = await db.Zadania.FindAsync(taskToMove.IdZadania);
            if (dbTask != null)
            {
                dbTask.KolumnaTablicy = targetColumn;
                dbTask.Status         = targetColumn;
                await db.SaveChangesAsync();
            }
        }
        catch (Exception ex)
        {
            // Rollback optimistic update – reload board
            taskModalError = $"Błąd przenoszenia zadania: {ex.Message}";
            await OnParametersSetAsync();
        }
    }

    private List<object> displayedMembers = new(); // mixed: owner entry + TablicaUzytkownik entries

    // ── Invite panel state ────────────────────────
    private bool showInvitePanel;
    private string inviteSearchQuery = "";
    private List<Uzytkownik> inviteSearchResults = new();
    private Uzytkownik? inviteSelectedUser;
    private string inviteSelectedRole = "member";
    private bool isInviteSearching;
    private bool isInviteSaving;
    private string? inviteSuccessMsg;
    private string? inviteErrorMsg;
    private List<TablicaUzytkownik> boardMembers = new();
    private System.Threading.Timer? _debounceTimer;

    // ── Avatar palette ─────────────────────────────
    private static readonly string[] AvatarColors =
    [
        "#0052CC", "#00875A", "#FF5630", "#FF8B00",
        "#6554C0", "#00B8D9", "#172B4D", "#403294"
    ];

    private static string GetAvatarColor(string name) =>
        AvatarColors[Math.Abs(name.GetHashCode()) % AvatarColors.Length];

    private static string RoleLabel(string rola) => rola switch
    {
        "owner"  => "Właściciel",
        "admin"  => "Administrator",
        "viewer" => "Obserwator",
        _        => "Członek"
    };

    // ── Lifecycle ──────────────────────────────────
    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        showDeleteConfirm = false;
        showInvitePanel = false;
        board = null;
        canDelete = false;
        canInvite = false;
        displayedMembers = new();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is not { IsAuthenticated: true }) { isLoading = false; return; }

        var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(idClaim, out int uid) && uid > 0)
        {
            currentUserId = uid;
        }
        else
        {
            var email = user.FindFirst(ClaimTypes.Email)?.Value;
            if (!string.IsNullOrEmpty(email))
            {
                using var ls = ScopeFactory.CreateScope();
                var ldb = ls.ServiceProvider.GetRequiredService<AppDbContext>();
                currentUserId = (await ldb.Uzytkownicy.FirstOrDefaultAsync(u => u.Email == email))?.IdUzytkownika ?? 0;
            }
        }

        // Load current user info for comment avatar
        if (currentUserId > 0)
        {
            using var us = ScopeFactory.CreateScope();
            var udb = us.ServiceProvider.GetRequiredService<AppDbContext>();
            var me = await udb.Uzytkownicy.FindAsync(currentUserId);
            if (me != null)
            {
                currentUserName      = me.NazwaUzytkownika;
                currentUserAvatarUrl = me.AvatarUrl;
            }
        }

        if (currentUserId <= 0 || BoardId == null) { isLoading = false; return; }

        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

        board = await db.Tablice
            .Include(t => t.Owner)
            .Include(t => t.TabliceUzyt)
                .ThenInclude(tu => tu.Uzytkownik)
            .Include(t => t.Zadania)
                .ThenInclude(z => z.UzytkownikPrzypisany)
            .FirstOrDefaultAsync(t =>
                t.IdTablicy == BoardId &&
                (t.IdUzytkownikaOwner == currentUserId ||
                 t.TabliceUzyt.Any(tu => tu.IdUzytkownika == currentUserId)));

        if (board != null)
        {
            var isOwner = board.IdUzytkownikaOwner == currentUserId;
            var isAdmin = board.TabliceUzyt
                .Any(tu => tu.IdUzytkownika == currentUserId && tu.Rola == "admin");

            canDelete  = isOwner || isAdmin;
            canInvite  = isOwner || isAdmin;
            canAddTask = isOwner || isAdmin ||
                         board.TabliceUzyt.Any(tu =>
                             tu.IdUzytkownika == currentUserId &&
                             tu.Rola == "member");
            // viewer => canAddTask stays false

            boardMembers = board.TabliceUzyt.ToList();
        }

        isLoading = false;
    }

    // ── Invite panel ───────────────────────────────
    private void OpenInvitePanel()
    {
        inviteSearchQuery = "";
        inviteSearchResults = new();
        inviteSelectedUser = null;
        inviteSelectedRole = "member";
        inviteSuccessMsg = null;
        inviteErrorMsg = null;
        showInvitePanel = true;
    }

    private void CloseInvitePanel()
    {
        showInvitePanel = false;
        _debounceTimer?.Dispose();
    }

    private void OnInviteSearchInput(ChangeEventArgs e)
    {
        inviteSearchQuery = e.Value?.ToString() ?? "";
        inviteSelectedUser = null;
        inviteErrorMsg = null;
        inviteSuccessMsg = null;
        inviteSearchResults = new();

        _debounceTimer?.Dispose();

        if (inviteSearchQuery.Length < 2)
            return;

        _debounceTimer = new System.Threading.Timer(async _ =>
        {
            await SearchUsersAsync(inviteSearchQuery);
        }, null, 300, System.Threading.Timeout.Infinite);
    }

    private async Task SearchUsersAsync(string query)
    {
        isInviteSearching = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            // Already-in-board ids to exclude
            var excludeIds = boardMembers.Select(m => m.IdUzytkownika).ToHashSet();
            excludeIds.Add(board!.IdUzytkownikaOwner);

            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            // PostgreSQL ILIKE — case-insensitive substring search on name AND email
            var pattern = $"%{query.Replace("%", "\\%").Replace("_", "\\_")}%";

            inviteSearchResults = await db.Uzytkownicy
                .Where(u =>
                    !excludeIds.Contains(u.IdUzytkownika) &&
                    (EF.Functions.ILike(u.NazwaUzytkownika, pattern) ||
                     EF.Functions.ILike(u.Email, pattern)))
                .OrderBy(u => u.NazwaUzytkownika)
                .Take(8)
                .ToListAsync();
        }
        catch
        {
            inviteSearchResults = new();
        }
        finally
        {
            isInviteSearching = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SelectInviteUser(Uzytkownik user)
    {
        inviteSelectedUser = user;
        inviteSearchQuery = user.NazwaUzytkownika;
        inviteSearchResults = new();
        inviteErrorMsg = null;
        inviteSuccessMsg = null;
    }

    private void ClearInviteSelection()
    {
        inviteSelectedUser = null;
        inviteSearchQuery = "";
        inviteSearchResults = new();
    }

    private void SetRoleMember(ChangeEventArgs _) => inviteSelectedRole = "member";
    private void SetRoleViewer(ChangeEventArgs _) => inviteSelectedRole = "viewer";
    private void SetRoleAdmin(ChangeEventArgs _)  => inviteSelectedRole = "admin";

    private async Task AddUserToBoardAsync()
    {
        if (inviteSelectedUser == null || board == null) return;

        isInviteSaving = true;
        inviteErrorMsg = null;
        inviteSuccessMsg = null;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            var alreadyExists = await db.TabliceUzytkownicy
                .AnyAsync(tu => tu.IdTablicy == board.IdTablicy &&
                                tu.IdUzytkownika == inviteSelectedUser.IdUzytkownika);

            if (alreadyExists)
            {
                inviteErrorMsg = $"{inviteSelectedUser.NazwaUzytkownika} jest już członkiem tej tablicy.";
                return;
            }

            var entry = new TablicaUzytkownik
            {
                IdTablicy      = board.IdTablicy,
                IdUzytkownika  = inviteSelectedUser.IdUzytkownika,
                Rola           = inviteSelectedRole,
                DataDolaczenia = DateTime.UtcNow,
            };

            db.TabliceUzytkownicy.Add(entry);
            await db.SaveChangesAsync();

            // Load the full nav property for the members list display
            entry.Uzytkownik = inviteSelectedUser;
            boardMembers.Add(entry);

            inviteSuccessMsg = $"✅ {inviteSelectedUser.NazwaUzytkownika} został dodany jako {RoleLabel(inviteSelectedRole)}.";
            ClearInviteSelection();
        }
        catch (Exception ex)
        {
            inviteErrorMsg = $"Błąd: {ex.Message}";
        }
        finally
        {
            isInviteSaving = false;
        }
    }

    // ── Task helpers ────────────────────────────────
    private IEnumerable<Zadanie> GetTasksByColumn(string columnName) =>
