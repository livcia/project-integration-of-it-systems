@using jira.DbModels

<div class="ticket-card @PriorityClass @(IsDragging ? "ticket-card--dragging" : "")"
     draggable="true"
     @ondragstart="HandleDragStart"
     @ondragend="HandleDragEnd"
     @onclick="HandleClick"
     role="button"
     tabindex="0"
     @onkeydown="HandleKeyDown"
     title="@Task.TytulZadania">
    <div class="ticket-card-header">
        <span class="ticket-priority-dot" title="Priorytet: @Task.Priorytet"></span>
        <span class="ticket-id">#@DisplayId</span>
        <span class="ticket-drag-handle" title="Przeciągnij">⠿</span>
    </div>
    <h6 class="ticket-title">@Task.TytulZadania</h6>
    <div class="ticket-footer">
        <div class="ticket-footer-left">
            <span class="ticket-priority-badge ticket-priority-badge--@Task.Priorytet.ToLower()">@PriorityLabel</span>
            <span class="ticket-age" title="@Task.DataStworzenia.ToLocalTime().ToString("dd.MM.yyyy HH:mm")">@RelativeAge</span>
        </div>
        @if (Task.UzytkownikPrzypisany != null)
        {
            <div class="ticket-assignee" title="Przypisane do: @Task.UzytkownikPrzypisany.NazwaUzytkownika"
                 style="background: @GetAvatarColor(Task.UzytkownikPrzypisany.NazwaUzytkownika)">
                @if (!string.IsNullOrEmpty(Task.UzytkownikPrzypisany.AvatarUrl))
                {
                    <img src="@Task.UzytkownikPrzypisany.AvatarUrl"
                         alt="@Task.UzytkownikPrzypisany.NazwaUzytkownika"
                         class="ticket-assignee-img" />
                }
                else
                {
                    @Task.UzytkownikPrzypisany.NazwaUzytkownika.Substring(0, 1).ToUpperInvariant()
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Zadanie Task { get; set; } = null!;
    [Parameter] public EventCallback<Zadanie> OnClick { get; set; }
    [Parameter] public EventCallback<Zadanie> OnDragStart { get; set; }
    [Parameter] public EventCallback OnDragEnd { get; set; }

    private bool IsDragging { get; set; }

    private async Task HandleClick() => await OnClick.InvokeAsync(Task);

    private async Task HandleDragStart(DragEventArgs e)
    {
        IsDragging = true;
        await OnDragStart.InvokeAsync(Task);
    }

    private async Task HandleDragEnd(DragEventArgs e)
    {
        IsDragging = false;
        await OnDragEnd.InvokeAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == " ")
            await OnClick.InvokeAsync(Task);
    }

    // Deterministyczny wielocyfrowy ID oparty na prawdziwym ID zadania
    private string DisplayId
    {
        get
        {
            var seed = Task.IdZadania * 131071 + 47;
            var pseudo = (seed ^ (seed >> 16)) * 0x45d9f3b;
            pseudo = (pseudo ^ (pseudo >> 16)) * 0x45d9f3b;
            pseudo = pseudo ^ (pseudo >> 16);
            var display = Math.Abs(pseudo) % 900_000 + 100_000;
            return display.ToString();
        }
    }

    private string RelativeAge
    {
        get
        {
            var age = DateTime.UtcNow - Task.DataStworzenia;
            if (age.TotalMinutes < 1)   return "teraz";
            if (age.TotalMinutes < 60)  return $"{(int)age.TotalMinutes}m";
            if (age.TotalHours   < 24)  return $"{(int)age.TotalHours}h";
            if (age.TotalDays    < 14)  return $"{(int)age.TotalDays}d";
            if (age.TotalDays    < 60)  return $"{(int)(age.TotalDays / 7)}tyg";
            if (age.TotalDays    < 365) return $"{(int)(age.TotalDays / 30)}mies";
            return $"{(int)(age.TotalDays / 365)}l";
        }
    }

    private string PriorityClass => Task.Priorytet.ToLower() switch
    {
        "wysoki" or "high"   => "ticket-card--high",
        "niski"  or "low"    => "ticket-card--low",
        _                    => "ticket-card--medium"
    };

    private string PriorityLabel => Task.Priorytet.ToLower() switch
    {
        "wysoki" or "high"   => "Wysoki",
        "niski"  or "low"    => "Niski",
        _                    => "Średni"
    };

    private static readonly string[] AvatarColors =
    [
        "#0052CC", "#00875A", "#FF5630", "#FF8B00",
        "#6554C0", "#00B8D9", "#172B4D", "#403294"
    ];

    private static string GetAvatarColor(string name) =>
        AvatarColors[Math.Abs(name.GetHashCode()) % AvatarColors.Length];
}