# Skopiuj ten plik jako .env i uzupełnij wartości.
# W CI/CD (GitHub Actions) ustawić te wartości jako GitHub Secrets.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jira_user
POSTGRES_PASSWORD=change_me_before_use
POSTGRES_DB=jira_db

GOOGLE_CLIENT_ID=client_id_z_google
GOOGLE_CLIENT_SECRET=client_secret_z_google
GITHUB_CLIENT_ID=client_id_z_github
GITHUB_CLIENT_SECRET=client_secret_z_github

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=your_email
SENDGRID_FROM_NAME=System Jira